// ============================================================
// Bayi Sipariş Sistemi — Prisma Schema
// Stack: Next.js 14 + Supabase (PostgreSQL) + Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & KULLANICI
// ============================================================

// Supabase Auth ile eşleşen kullanıcı tablosu.
// Supabase'deki auth.users tablosuna referans verir.
model User {
  id        String   @id @default(uuid()) // Supabase auth.users id ile aynı
  email     String   @unique
  role      UserRole @default(DEALER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealer Dealer? // Rol DEALER ise ilişkili bayi kaydı
}

enum UserRole {
  ADMIN  // Firma sahibi / yönetici
  DEALER // Bayi
}

// ============================================================
// BAYİ
// ============================================================

model Dealer {
  id           String       @id @default(cuid())
  code         String       @unique // ör. "ANK-001"
  name         String
  email        String       @unique
  phone        String?
  address      String?
  region       String?
  taxNumber    String?
  paymentTerms Int          @default(30) // Vade gün sayısı
  status       DealerStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Auth bağlantısı
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Fiyat grubu (opsiyonel — null ise taban fiyat uygulanır)
  priceGroupId String?
  priceGroup   PriceGroup? @relation(fields: [priceGroupId], references: [id])

  // İlişkiler
  priceOverrides DealerPriceOverride[]
  orders         Order[]
  payments       Payment[]
}

enum DealerStatus {
  ACTIVE   // Aktif
  PASSIVE  // Pasif
  BLOCKED  // Bloke
}

// ============================================================
// ÜRÜN
// ============================================================

model Product {
  id          String        @id @default(cuid())
  code        String        @unique // ör. "PRD-001"
  name        String
  description String?
  category    String?
  unit        String        @default("Adet") // Koli, Adet, Kg...
  unitSize    String?       // ör. "6 adet/koli"
  basePrice   Decimal       @db.Decimal(12, 2)
  vatRate     Decimal       @default(20) @db.Decimal(5, 2) // %20
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // İlişkiler
  priceGroupRates    PriceGroupRate[]
  dealerOverrides    DealerPriceOverride[]
  orderItems         OrderItem[]
}

enum ProductStatus {
  ACTIVE
  PASSIVE
}

// ============================================================
// FİYAT GRUPLARI & İNDİRİMLER
// ============================================================

// Fiyat grubu tanımı (Grup A, B, C...)
model PriceGroup {
  id          String   @id @default(cuid())
  code        String   @unique // "GROUP_A"
  name        String           // "Grup A"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dealers Dealer[]
  rates   PriceGroupRate[]
}

// Grup x Ürün indirim oranı
// Her grup için her ürüne ayrı indirim tanımlanabilir
model PriceGroupRate {
  id             String   @id @default(cuid())
  priceGroupId   String
  productId      String
  discountRate   Decimal  @db.Decimal(5, 2) // ör. 12.00 = %12
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  priceGroup PriceGroup @relation(fields: [priceGroupId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([priceGroupId, productId])
}

// Bayi x Ürün özel indirim (grup indirimi yerine veya üstüne)
model DealerPriceOverride {
  id           String   @id @default(cuid())
  dealerId     String
  productId    String
  discountRate Decimal  @db.Decimal(5, 2) // ör. 15.00 = %15
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dealer  Dealer  @relation(fields: [dealerId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([dealerId, productId])
}

// Fiyat hesaplama kuralı (sistem genelinde tek kayıt)
model PriceSettings {
  id              String          @id @default(cuid())
  overrideRule    OverrideRule    @default(REPLACE)
  // REPLACE: özel indirim grup indirimin yerine geçer
  // STACK:   grup + özel üst üste uygulanır
  // HIGHER:  ikisinden büyük olan seçilir
  updatedAt       DateTime        @updatedAt
}

enum OverrideRule {
  REPLACE // Özel indirim grup indirimin yerine geçer
  STACK   // Üst üste uygulanır: (1-grup%) * (1-özel%)
  HIGHER  // İkisinden büyük olan seçilir
}

// ============================================================
// SİPARİŞ
// ============================================================

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique // ör. "ORD-2026-00412"
  dealerId    String
  status      OrderStatus @default(PENDING)
  orderDate   DateTime    @default(now())
  deliveryDate DateTime?
  note        String?
  
  // Toplam tutarlar (KDV hariç / dahil)
  subtotal    Decimal     @db.Decimal(12, 2) // KDV hariç
  vatAmount   Decimal     @db.Decimal(12, 2) // KDV tutarı
  total       Decimal     @db.Decimal(12, 2) // KDV dahil
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  dealer    Dealer      @relation(fields: [dealerId], references: [id])
  items     OrderItem[]
}

enum OrderStatus {
  PENDING    // Onay bekliyor
  CONFIRMED  // Onaylandı
  PROCESSING // Hazırlanıyor
  SHIPPED    // Kargoya verildi
  DELIVERED  // Teslim edildi
  CANCELLED  // İptal
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  
  // Sipariş anındaki fiyat snapshot'ı (fiyat değişse de geçmişe etki etmesin)
  basePrice        Decimal @db.Decimal(12, 2) // Sipariş anındaki taban fiyat
  discountRate     Decimal @db.Decimal(5, 2)  // Uygulanan indirim oranı
  discountSource   String  // "GROUP_A", "OVERRIDE", "NONE"
  unitPrice        Decimal @db.Decimal(12, 2) // Net birim fiyat (indirim sonrası)
  vatRate          Decimal @db.Decimal(5, 2)  // KDV oranı
  lineTotal        Decimal @db.Decimal(12, 2) // miktar * unitPrice (KDV hariç)
  lineTotalWithVat Decimal @db.Decimal(12, 2) // KDV dahil satır toplam

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// ============================================================
// ÖDEME & BAKİYE
// ============================================================

model Payment {
  id          String        @id @default(cuid())
  dealerId    String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?       // Dekont / havale numarası
  note        String?
  paymentDate DateTime      @default(now())
  createdAt   DateTime      @default(now())

  dealer Dealer @relation(fields: [dealerId], references: [id])
}

enum PaymentMethod {
  BANK_TRANSFER // Havale / EFT
  CHECK         // Çek
  CASH          // Nakit
  OTHER
}
